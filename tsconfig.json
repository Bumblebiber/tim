{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "packages/tim-core" },
    { "path": "packages/tim-store" },
    { "path": "packages/tim-sync-client" },
    { "path": "packages/tim-sync-server" },
    { "path": "packages/tim-cli" },
    { "path": "packages/tim-mcp" },
    { "path": "packages/tim-migrate" },
    { "path": "packages/tim-hooks" },
    { "path": "packages/tim-summarizer" },
    { "path": "packages/tim-skills" }
  ],
  "files": []
}
