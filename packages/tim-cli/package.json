{
  "name": "tim-cli",
  "version": "0.1.0-beta.1",
  "description": "TIM CLI: init, write, read, search, sync, doctor, visualize",
  "main": "dist/index.js",
  "bin": {
    "tim": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "!dist/**/__tests__/**"
  ],
  "dependencies": {
    "tim-core": "0.1.0-beta.1",
    "tim-store": "0.1.0-beta.1",
    "tim-sync-client": "0.1.0-beta.1",
    "tim-hooks": "0.1.0-beta.1",
    "tim-migrate": "0.1.0-beta.1",
    "tim-mcp": "0.1.0-beta.1",
    "tim-summarizer": "0.1.0-beta.1",
    "tim-skills": "0.1.0-beta.1",
    "better-sqlite3": "^11.7.0"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm --prefix ../.. run build",
    "test": "vitest run --root ../.. packages/tim-cli/src/__tests__",
    "postinstall": "node -e \"try{require('./dist/update-skills.js').updateSkills()}catch(e){}\""
  }
}
