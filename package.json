{
  "name": "tim",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "TIM \u2014 Theoretically Infinite Memory. Local-first, self-optimizing cognitive OS for AI agents.",
  "workspaces": [
    "packages/tim-core",
    "packages/tim-store",
    "packages/tim-sync-client",
    "packages/tim-sync-server",
    "packages/tim-cli",
    "packages/tim-mcp",
    "packages/tim-migrate",
    "packages/tim-hooks",
    "packages/tim-summarizer",
    "packages/tim-skills"
  ],
  "scripts": {
    "prepare": "npm run clean && npm run build",
    "build": "tsc -b && node scripts/ensure-executable-dist.mjs",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:build-pipeline": "npm run clean && node scripts/check-clean-output.mjs && npm run build && node scripts/check-build-output.mjs",
    "lint": "tsc -b --noEmit",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "fastembed": "^2.1.0"
  }
}
